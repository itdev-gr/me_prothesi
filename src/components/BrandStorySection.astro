---
import type { BrandStorySectionData } from '../data/brandStory';

interface Props {
  section: BrandStorySectionData;
  continued?: boolean;
}

const { section, continued = false } = Astro.props;
const bg = section.bg === 'lavender' ? '#F0EBE3' : '#FAFAF8';
const sectionKicker = section.sectionId.replace(/^section-/, '');
const firstPIndex = section.parts.findIndex((p) => p.type === 'p');
const isTaglineBlock = section.sectionId === 'section-11';
---

<section
  id={section.sectionId}
  class:list={['reveal', 'brand-story', continued && 'brand-story--continued']}
  style={`background: ${bg}; padding: 7rem 0;`}
>
  <div
    class="brand-story__grid"
    style="
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  "
  >
    <!-- Image -->
    <div
      class="brand-story__media"
      style={`
        order: ${section.imageLeft ? 0 : 1};
        border-radius: 12px;
        overflow: hidden;
        aspect-ratio: 4/5;
        background: #E8E0D5;
        box-shadow: 0 20px 60px rgba(0,0,0,0.08);
      `}
    >
      <img
        src={section.image}
        alt={section.title}
        style="width:100%; height:100%; object-fit:cover; object-position:center;"
        loading="lazy"
      />
    </div>

    <!-- Text -->
    <div class="brand-story__body" style={`order: ${section.imageLeft ? 1 : 0};`}>
      <p
        style="
        font-size: 0.62rem;
        font-weight: 500;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: #8B6F47;
        margin-bottom: 1.25rem;
        font-family: var(--font-body);
      "
      >
        {sectionKicker}
      </p>

      <h2
        style="
        font-family: var(--font-display);
        font-size: clamp(1.8rem, 3.5vw, 2.8rem);
        font-weight: 300;
        color: var(--ink);
        line-height: 1.15;
        letter-spacing: -0.01em;
        margin-bottom: 2rem;
      "
      >
        {section.title}
      </h2>

      <div style="display:flex; flex-direction:column; gap:1rem;">
        {
          section.parts.map((part, idx) => {
            if (part.type === 'p') {
              const taglineLead =
                isTaglineBlock && idx === firstPIndex && firstPIndex >= 0;
              return (
                <p
                  style={`
              font-family: var(--font-body);
              font-size: ${taglineLead ? 'clamp(1.15rem, 2.2vw, 1.35rem)' : '0.92rem'};
              font-weight: ${taglineLead ? '400' : '300'};
              font-style: ${taglineLead ? 'italic' : 'normal'};
              color: ${taglineLead ? 'var(--ink)' : 'var(--ink-soft)'};
              line-height: 1.8;
              letter-spacing: ${taglineLead ? '-0.02em' : 'normal'};
            `}
                >
                  {part.text}
                </p>
              );
            }
            if (part.type === 'h3') {
              return (
                <p
                  style="
              font-family: var(--font-body);
              font-size: 0.65rem;
              font-weight: 600;
              letter-spacing: 0.18em;
              text-transform: uppercase;
              color: #8B6F47;
              margin-top: 0.5rem;
            "
                >
                  {part.text}
                </p>
              );
            }
            if (part.type === 'ul') {
              return (
                <ul style="list-style:none; display:flex; flex-direction:column; gap:0;">
                  {part.items.map((item) => (
                    <li
                      style="
                  display: flex;
                  align-items: flex-start;
                  gap: 0.75rem;
                  padding: 0.75rem 0;
                  border-bottom: 1px solid rgba(28,23,18,0.08);
                  font-family: var(--font-body);
                  font-size: 0.88rem;
                  font-weight: 300;
                  color: var(--ink-soft);
                  line-height: 1.6;
                "
                    >
                      <span style="color:#8B6F47; font-weight:600; flex-shrink:0; margin-top:0.1rem;">→</span>
                      {item}
                    </li>
                  ))}
                </ul>
              );
            }
            return null;
          })
        }
      </div>
    </div>
  </div>
</section>

<style>
  .brand-story--continued {
    box-shadow: inset 0 1px 0 rgba(28, 23, 18, 0.06);
  }

  @media (hover: hover) and (pointer: fine) {
    .brand-story:hover .brand-story__media {
      transform: translateY(-3px);
      box-shadow: 0 26px 70px rgba(0, 0, 0, 0.1);
    }
  }

  .brand-story__media {
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }

  @media (max-width: 768px) {
    .brand-story__grid {
      grid-template-columns: 1fr !important;
      padding: 0 1.5rem !important;
      gap: 2.5rem !important;
    }
    .brand-story__media,
    .brand-story__body {
      order: 0 !important;
    }
  }
</style>
