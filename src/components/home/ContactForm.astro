---
---

<section id="contact" class="contact-section bg-blush py-16 md:py-24">
  <div class="mx-auto max-w-narrow px-6 md:px-12">
    <div class="contact-header text-center mb-10 md:mb-12">
      <h2 class="font-serif italic text-burgundy text-display-sm md:text-display font-semibold mb-3">
        Μίλα μας
      </h2>
      <p class="text-brand-body text-base md:text-lg leading-relaxed">
        Θα χαρούμε να ακούσουμε από εσένα.
      </p>
    </div>

    <form id="contact-form" class="contact-form space-y-5" novalidate>
      <input type="hidden" name="access_key" value="1da511ca-e924-4cce-a178-9024fe151b48" />
      <input type="hidden" name="subject" value="Νέο μήνυμα από meprothesi.gr" />
      <input type="hidden" name="from_name" value="meprothesi.gr" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

      <div class="grid md:grid-cols-2 gap-5">
        <label class="block">
          <span class="block text-sm font-medium text-brand-dark mb-1.5">Ονοματεπώνυμο</span>
          <input
            type="text"
            name="name"
            required
            autocomplete="name"
            class="w-full rounded-lg border border-burgundy/20 bg-white px-4 py-3 text-brand-dark placeholder:text-brand-body/50 focus:border-burgundy focus:ring-2 focus:ring-burgundy/30 focus:outline-none transition"
          />
        </label>
        <label class="block">
          <span class="block text-sm font-medium text-brand-dark mb-1.5">Email</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="w-full rounded-lg border border-burgundy/20 bg-white px-4 py-3 text-brand-dark placeholder:text-brand-body/50 focus:border-burgundy focus:ring-2 focus:ring-burgundy/30 focus:outline-none transition"
          />
        </label>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        <label class="block">
          <span class="block text-sm font-medium text-brand-dark mb-1.5">
            Τηλέφωνο <span class="text-brand-body/60 font-normal">(προαιρετικό)</span>
          </span>
          <input
            type="tel"
            name="phone"
            autocomplete="tel"
            class="w-full rounded-lg border border-burgundy/20 bg-white px-4 py-3 text-brand-dark placeholder:text-brand-body/50 focus:border-burgundy focus:ring-2 focus:ring-burgundy/30 focus:outline-none transition"
          />
        </label>
        <label class="block">
          <span class="block text-sm font-medium text-brand-dark mb-1.5">Λόγος επικοινωνίας</span>
          <select
            name="reason"
            required
            class="w-full rounded-lg border border-burgundy/20 bg-white px-4 py-3 text-brand-dark focus:border-burgundy focus:ring-2 focus:ring-burgundy/30 focus:outline-none transition appearance-none bg-no-repeat bg-right pr-10"
            style="background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 fill=%22none%22 viewBox=%220 0 24 24%22 stroke=%22%2376150C%22%3E%3Cpath stroke-linecap=%22round%22 stroke-linejoin=%22round%22 stroke-width=%222%22 d=%22M19 9l-7 7-7-7%22/%3E%3C/svg%3E'); background-size: 1rem; background-position: right 1rem center;"
          >
            <option value="">Διάλεξε…</option>
            <option value="Ενδιαφέρον για box">Ενδιαφέρον για box</option>
            <option value="Συνεργασία">Συνεργασία</option>
            <option value="Ερώτηση">Ερώτηση</option>
            <option value="Άλλο">Άλλο</option>
          </select>
        </label>
      </div>

      <label class="block">
        <span class="block text-sm font-medium text-brand-dark mb-1.5">Μήνυμα</span>
        <textarea
          name="message"
          required
          rows="5"
          class="w-full rounded-lg border border-burgundy/20 bg-white px-4 py-3 text-brand-dark placeholder:text-brand-body/50 focus:border-burgundy focus:ring-2 focus:ring-burgundy/30 focus:outline-none transition resize-y"
        ></textarea>
      </label>

      <div class="pt-2 flex flex-col items-center gap-4">
        <button
          type="submit"
          class="contact-submit inline-block bg-burgundy text-white font-medium text-base uppercase rounded-pill px-10 py-3.5 hover:bg-burgundy-light transition-colors duration-300 disabled:opacity-60 disabled:cursor-not-allowed"
        >
          ΑΠΟΣΤΟΛΗ
        </button>
        <p id="contact-status" class="text-sm min-h-[1.25rem] text-center" role="status" aria-live="polite"></p>
      </div>
    </form>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    gsap.from('.contact-header > *, .contact-form > *', {
      y: 25,
      opacity: 0,
      stagger: 0.08,
      duration: 0.7,
      ease: 'power3.out',
      scrollTrigger: { trigger: '.contact-section', start: 'top 80%' },
    });

    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form) return;
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const status = document.getElementById('contact-status') as HTMLParagraphElement;

    const setStatus = (message: string, tone: 'success' | 'error' | 'idle') => {
      status.textContent = message;
      status.classList.remove('text-burgundy', 'text-sage', 'text-red-600');
      if (tone === 'success') status.classList.add('text-sage');
      else if (tone === 'error') status.classList.add('text-red-600');
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const originalText = submitBtn.textContent ?? '';
      submitBtn.textContent = 'Αποστολή...';
      submitBtn.disabled = true;
      setStatus('', 'idle');

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData,
        });
        const data = await response.json();

        if (response.ok) {
          setStatus('Ευχαριστούμε! Το μήνυμά σου στάλθηκε.', 'success');
          form.reset();
          setTimeout(() => setStatus('', 'idle'), 6000);
        } else {
          setStatus(data.message || 'Κάτι πήγε στραβά. Δοκίμασε ξανά.', 'error');
        }
      } catch {
        setStatus('Κάτι πήγε στραβά. Δοκίμασε ξανά.', 'error');
      } finally {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    });
  });
</script>
