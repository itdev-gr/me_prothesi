---
const traits = [
  'θέλουν να δημιουργήσουν μικρές αλλαγές στην καθημερινότητα',
  'αναζητούν καθαρότητα σκέψης μέσα στον ρυθμό της ημέρας',
  'δυσκολεύονται να ξεκινήσουν χωρίς να νιώσουν πρώτα έτοιμοι',
  'φροντίζουν πολλούς ρόλους ταυτόχρονα',
  'θέλουν χώρο για προσωπική επανασύνδεση',
];
const psychographics = [
  'Αναζητούν εσωτερική καθαρότητα',
  'Έχουν επίγνωση αλλά δυσκολεύονται στη δράση',
  'Θέλουν μικρές, ρεαλιστικές παρεμβάσεις',
];
---

<section id="audience" class="audience-section bg-off-white py-12 md:py-16">
  <div class="mx-auto max-w-content px-6 md:px-12 lg:px-20">
    <h2 class="audience-heading font-serif text-[2.125rem] md:text-[2.375rem] font-medium text-burgundy text-center mb-4">Σε ποιους απευθύνεται</h2>
    <p class="text-brand-body text-base md:text-lg text-center mb-10 max-w-2xl mx-auto">Τα boxes Με Πρόθεση απευθύνονται σε ανθρώπους που:</p>
    <ul class="audience-list space-y-4 max-w-2xl mx-auto mb-12">
      {traits.map((trait) => (
        <li class="audience-item flex items-start gap-4">
          <svg class="w-5 h-5 text-burgundy flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span class="text-brand-body text-base md:text-lg">{trait}</span>
        </li>
      ))}
    </ul>
    <div class="audience-psycho bg-blush rounded-2xl p-6 md:p-8 max-w-2xl mx-auto">
      <p class="text-burgundy font-semibold text-sm uppercase tracking-wide mb-4">Γυναίκες & άνδρες 28–45, σε φάση μετάβασης</p>
      <ul class="space-y-2 mb-4">
        {psychographics.map((item) => (
          <li class="flex items-start gap-3">
            <span class="w-1.5 h-1.5 rounded-full bg-sage flex-shrink-0 mt-2"></span>
            <span class="text-brand-body text-sm md:text-base">{item}</span>
          </li>
        ))}
      </ul>
      <p class="text-sage text-sm italic">
        Με κόπωση από το "θετικό thinking" — θέλουν δομή, όχι απλά έμπνευση.
      </p>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);
  document.addEventListener('DOMContentLoaded', () => {
    gsap.from('.audience-heading', { y: 30, opacity: 0, duration: 0.8, ease: 'power3.out', scrollTrigger: { trigger: '.audience-section', start: 'top 75%' } });
    gsap.from('.audience-item', { x: -20, opacity: 0, stagger: 0.1, duration: 0.5, ease: 'power2.out', scrollTrigger: { trigger: '.audience-list', start: 'top 80%' } });
    gsap.from('.audience-psycho', { y: 30, opacity: 0, duration: 0.8, ease: 'power3.out', scrollTrigger: { trigger: '.audience-psycho', start: 'top 85%' } });
  });
</script>
