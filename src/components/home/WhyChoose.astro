---
const benefits = [
  { title: 'Δομή', description: 'μικρά, σαφή βήματα που μπορείς να εφαρμόσεις στην πραγματική ημέρα σου' },
  { title: 'Σύντομες πρακτικές παύσης', description: 'που βοηθούν να βγεις από τον αυτόματο ρυθμό' },
  { title: 'Ενίσχυση της προσωπικής κατεύθυνσης', description: 'ώστε οι επιλογές σου να συνδέονται περισσότερο με αυτό που έχει σημασία για εσένα' },
  { title: 'Καθημερινή εφαρμογή', description: 'χωρίς να χρειάζεται ειδικός χρόνος ή προετοιμασία' },
  { title: 'Μια εμπειρία προσωπικής επανασύνδεσης', description: 'μέσα από μικρές συνειδητές στιγμές' },
];
---

<section class="whychoose-section bg-white py-12 md:py-16">
  <div class="mx-auto max-w-content px-6 md:px-12 lg:px-20">
    <h2 class="whychoose-heading font-serif text-[2.125rem] md:text-[2.375rem] font-medium text-burgundy text-center mb-4">Γιατί να επιλέξετε τα Boxes</h2>
    <p class="text-brand-body text-base md:text-lg text-center mb-12 max-w-3xl mx-auto leading-relaxed">
      Τα boxes Με Πρόθεση δημιουργούν έναν μικρό, δομημένο χώρο μέσα στην καθημερινότητα για να σταθείς, να παρατηρήσεις και να κινηθείς με μεγαλύτερη συνειδητότητα. Προσφέρουν:
    </p>
    <div class="whychoose-list space-y-5 max-w-3xl mx-auto mb-10">
      {benefits.map((benefit) => (
        <div class="whychoose-item flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-blush flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-burgundy" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div>
            <h4 class="text-brand-dark font-bold text-lg">{benefit.title}</h4>
            <p class="text-brand-body text-base leading-relaxed">{benefit.description}</p>
          </div>
        </div>
      ))}
    </div>
    <p class="whychoose-closing text-center font-serif italic text-brand-dark text-xl md:text-2xl font-semibold">
      Κάθε box είναι μια ήρεμη αρχή. <span class="text-burgundy not-italic">Με Πρόθεση.</span>
    </p>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);
  document.addEventListener('DOMContentLoaded', () => {
    gsap.from('.whychoose-heading', { y: 30, opacity: 0, duration: 0.8, ease: 'power3.out', scrollTrigger: { trigger: '.whychoose-section', start: 'top 75%' } });
    gsap.from('.whychoose-item', { x: -30, opacity: 0, stagger: 0.12, duration: 0.6, ease: 'power2.out', scrollTrigger: { trigger: '.whychoose-list', start: 'top 80%' } });
    gsap.from('.whychoose-closing', { y: 20, opacity: 0, duration: 0.8, ease: 'power3.out', scrollTrigger: { trigger: '.whychoose-closing', start: 'top 90%' } });
  });
</script>
