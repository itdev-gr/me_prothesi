---
const boxes = [
  {
    number: '01',
    title: 'Pause Mode',
    subtitle: 'Μικρές παύσεις για πιο συνειδητή εργασία',
    description: 'Βοηθά να αναγνωρίζεις τον αυτόματο πιλότο της καθημερινής εργασίας και να δημιουργείς μικρές στιγμές επαναφοράς μέσα στην ημέρα.',
  },
  {
    number: '02',
    title: 'Στέκομαι Με Επιείκεια',
    subtitle: 'Για τη Μητέρα Μέσα Μου',
    description: 'Μικρές πρακτικές αυτοφροντίδας για γυναίκες που φροντίζουν τους άλλους και χρειάζονται χώρο να σταθούν δίπλα στον εαυτό τους.',
  },
  {
    number: '03',
    title: 'Με Πρόθεση – Ξεκινώ',
    subtitle: 'Δράση χωρίς τελειότητα',
    description: 'Υποστηρίζει μικρές πράξεις έναρξης όταν η αναμονή της τελειότητας καθυστερεί το επόμενο βήμα.',
  },
  {
    number: '04',
    title: 'Επιλέγω να βλέπω',
    subtitle: 'Η δύναμη της συνειδητής εστίασης στο θετικό',
    description: 'Βοηθά να εκπαιδεύσεις την προσοχή σου ώστε να αναγνωρίζεις περισσότερο ό,τι ήδη λειτουργεί στη ζωή σου.',
  },
];
---

<section id="boxes" class="boxes-section bg-white py-12 md:py-16">
  <div class="mx-auto max-w-content px-6 md:px-12 lg:px-20">
    <h2 class="boxes-heading font-serif text-[2.125rem] md:text-[2.375rem] font-medium text-burgundy text-center mb-12">Τα 4 πρώτα Boxes της σειράς</h2>
    <div class="boxes-grid grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
      {boxes.map((box) => (
        <div class="box-card bg-off-white rounded-2xl p-6 md:p-8 border border-transparent hover:border-burgundy/20 hover:shadow-xl transition-all duration-300">
          <p class="text-burgundy font-sans font-bold text-xs uppercase tracking-widest mb-3">Box {box.number}</p>
          <h3 class="font-serif text-xl md:text-2xl font-semibold text-brand-dark mb-1">{box.title}</h3>
          <p class="text-burgundy font-sans font-semibold text-sm mb-4">{box.subtitle}</p>
          <p class="text-brand-body font-sans text-base leading-relaxed">{box.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);
  document.addEventListener('DOMContentLoaded', () => {
    gsap.from('.boxes-heading', { y: 30, opacity: 0, duration: 0.8, ease: 'power3.out', scrollTrigger: { trigger: '.boxes-section', start: 'top 75%' } });
    document.querySelectorAll('.box-card').forEach((card, i) => {
      gsap.from(card, { y: 50, opacity: 0, scale: 0.95, delay: i * 0.15, duration: 0.8, ease: 'power3.out', scrollTrigger: { trigger: card, start: 'top 90%' } });
    });
  });
</script>
