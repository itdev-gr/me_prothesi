<section class="finalcta-section bg-brand-dark py-14 md:py-20">
  <div class="mx-auto max-w-narrow px-6 md:px-12 text-center">
    <div class="finalcta-content">
      <p class="text-white/80 text-lg md:text-xl leading-relaxed mb-2">Μερικές αλλαγές ξεκινούν όταν εμφανίζεται η βεβαιότητα.</p>
      <p class="text-white/80 text-lg md:text-xl leading-relaxed mb-2">Άλλες ξεκινούν νωρίτερα.</p>
      <p class="font-serif italic text-blush text-2xl md:text-3xl lg:text-4xl font-semibold mt-6 mb-10">Με Πρόθεση.</p>
      <a href="#boxes" class="inline-block bg-burgundy text-white font-medium text-base uppercase rounded-pill px-10 py-3.5 hover:bg-burgundy-light transition-colors duration-300">
        ΑΝΑΚΑΛΥΨΕ ΤΟ ΠΡΩΤΟ ΣΟΥ BOX
      </a>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);
  document.addEventListener('DOMContentLoaded', () => {
    gsap.from('.finalcta-content > *', { y: 25, opacity: 0, stagger: 0.12, duration: 0.7, ease: 'power3.out', scrollTrigger: { trigger: '.finalcta-section', start: 'top 75%' } });
  });
</script>
