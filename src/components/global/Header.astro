---
---

<header class="bg-blush sticky top-0 z-50 shadow-sm">
  <div class="mx-auto max-w-content px-6 md:px-12 lg:px-20">
    <div class="flex items-center justify-between h-20 md:h-[80px]">
      <nav class="hidden lg:block flex-1">
        <ul class="flex items-center gap-8">
          <li><a href="#home" class="nav-link text-burgundy text-lg font-bold hover:opacity-70 transition-opacity">Αρχική</a></li>
          <li><a href="#what-is" class="nav-link text-burgundy text-lg font-bold hover:opacity-70 transition-opacity">Τι Είναι</a></li>
          <li><a href="#how-it-works" class="nav-link text-burgundy text-lg font-bold hover:opacity-70 transition-opacity">Πώς Λειτουργεί</a></li>
        </ul>
      </nav>
      <button id="mobile-menu-btn" class="lg:hidden text-burgundy p-2" aria-label="Μενού">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <a href="#home" class="nav-link relative z-10 -my-6 flex-shrink-0 mx-6 lg:mx-10">
        <div class="w-24 h-24 md:w-28 md:h-28 rounded-full bg-blush border-4 border-burgundy/10 flex items-center justify-center shadow-lg overflow-hidden p-2">
          <img src="/images/logo/me-prothesi-logo-sm.png" alt="Με Πρόθεση" class="w-full h-full object-contain" />
        </div>
      </a>
      <nav class="hidden lg:block flex-1">
        <ul class="flex items-center justify-end gap-8">
          <li><a href="#boxes" class="nav-link text-burgundy text-lg font-bold hover:opacity-70 transition-opacity">Τα Boxes</a></li>
          <li><a href="#audience" class="nav-link text-burgundy text-lg font-bold hover:opacity-70 transition-opacity">Σε Ποιους</a></li>
          <li><a href="#creator" class="nav-link text-burgundy text-lg font-bold hover:opacity-70 transition-opacity">Δημιουργός</a></li>
        </ul>
      </nav>
      <a href="#boxes" class="lg:hidden nav-link text-burgundy p-2">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </a>
    </div>
  </div>
  <div id="mobile-menu" class="lg:hidden fixed inset-0 z-40 pointer-events-none">
    <div id="mobile-overlay" class="absolute inset-0 bg-black/50 opacity-0 transition-opacity duration-300"></div>
    <nav id="mobile-nav" class="absolute top-0 left-0 w-72 h-full bg-blush shadow-xl transform -translate-x-full transition-transform duration-300">
      <div class="pt-24 px-6">
        <ul class="space-y-4">
          <li><a href="#home" class="mobile-nav-link block text-burgundy font-bold text-xl py-2 border-b border-burgundy/10">Αρχική</a></li>
          <li><a href="#what-is" class="mobile-nav-link block text-burgundy font-bold text-xl py-2 border-b border-burgundy/10">Τι Είναι</a></li>
          <li><a href="#how-it-works" class="mobile-nav-link block text-burgundy font-bold text-xl py-2 border-b border-burgundy/10">Πώς Λειτουργεί</a></li>
          <li><a href="#boxes" class="mobile-nav-link block text-burgundy font-bold text-xl py-2 border-b border-burgundy/10">Τα Boxes</a></li>
          <li><a href="#audience" class="mobile-nav-link block text-burgundy font-bold text-xl py-2 border-b border-burgundy/10">Σε Ποιους</a></li>
          <li><a href="#creator" class="mobile-nav-link block text-burgundy font-bold text-xl py-2 border-b border-burgundy/10">Δημιουργός</a></li>
        </ul>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-overlay');
  const nav = document.getElementById('mobile-nav');
  let isOpen = false;
  function closeMenu() {
    if (!isOpen) return;
    isOpen = false;
    overlay!.classList.remove('opacity-100'); overlay!.classList.add('opacity-0');
    nav!.classList.remove('translate-x-0'); nav!.classList.add('-translate-x-full');
    setTimeout(() => menu!.classList.add('pointer-events-none'), 300);
  }
  function toggleMenu() {
    isOpen = !isOpen;
    if (isOpen) {
      menu!.classList.remove('pointer-events-none');
      overlay!.classList.remove('opacity-0'); overlay!.classList.add('opacity-100');
      nav!.classList.remove('-translate-x-full'); nav!.classList.add('translate-x-0');
    } else { closeMenu(); }
  }
  btn?.addEventListener('click', toggleMenu);
  overlay?.addEventListener('click', closeMenu);
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
