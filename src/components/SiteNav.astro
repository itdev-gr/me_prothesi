---
import { SITE } from "../constants/site.ts";
---

<header class="fixed left-0 right-0 top-0 z-50 border-b border-stone-200/80 bg-cream/85 backdrop-blur-md">
  <nav
    class="mx-auto flex max-w-5xl items-center justify-between px-8 py-4"
    aria-label="Κύρια πλοήγηση"
  >
    <a href="/" class="font-serif text-lg font-medium tracking-tight text-[#8B1A1A] no-underline">
      {SITE.name}
    </a>
    <a
      href={SITE.instagramUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs uppercase tracking-widest text-stone-500 no-underline transition-colors hover:text-ink"
    >
      Instagram
    </a>
  </nav>
</header>
