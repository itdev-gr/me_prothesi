---
import Layout from '../layouts/Layout.astro';
import BrandStorySection from '../components/BrandStorySection.astro';
import { brandStorySections } from '../data/brandStory';
---

<Layout title="Με Πρόθεση">
  <link
    slot="head"
    rel="preload"
    href="/images/hero2.mp4"
    as="video"
    type="video/mp4"
  />
  <section
    class="site-hero"
    style="
  min-height: 100vh;
  min-height: 100svh;
  background: #F6F2ED;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: stretch;
  overflow: hidden;
"
  >
    <!-- LEFT: Text -->
    <div class="site-hero__content">
      <div class="site-hero__intro">
        <p class="site-hero__kicker">Δημιουργημένο από ψυχοθεραπεύτρια</p>

        <h1 class="site-hero__title" id="hero-title">
          <span class="site-hero__title-line1">Η αλλαγή ξεκινά</span>
          <span class="site-hero__title-accent">Με Πρόθεση.</span>
        </h1>

        <div class="site-hero__rule" aria-hidden="true"></div>

        <p class="site-hero__lead">Μικρές παύσεις για πιο συνειδητή εργασία.</p>

        <p class="site-hero__body">
          Δομημένες ψυχοεκπαιδευτικές εμπειρίες σε μορφή τελετουργίας. Η αλλαγή δεν ξεκινά εξωτερικά· ξεκινά εσωτερικά.
        </p>
      </div>

      <div class="site-hero__stats">
        <div class="site-hero__stat">
          <p class="site-hero__stat-num">7–10</p>
          <p class="site-hero__stat-label">ημέρες / box</p>
        </div>
        <div class="site-hero__stat-divider" aria-hidden="true"></div>
        <div class="site-hero__stat">
          <p class="site-hero__stat-num">10+</p>
          <p class="site-hero__stat-label">κάρτες ασκήσεων</p>
        </div>
        <div class="site-hero__stat-divider" aria-hidden="true"></div>
        <div class="site-hero__stat">
          <p class="site-hero__stat-num">1</p>
          <p class="site-hero__stat-label">ψυχοθεραπεύτρια</p>
        </div>
      </div>
    </div>

    <!-- RIGHT: Hero video -->
    <div
      class="site-hero__media"
      style="
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    min-height: 100svh;
    background: #C4956A;
  "
    >
      <video
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        aria-label="Pause Mode"
        style="
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
      "
      >
        <source src="/images/hero2.mp4" type="video/mp4" />
      </video>
      <div
        style="
        position: absolute; inset: 0;
        background: linear-gradient(to right, rgba(196,149,106,0.35) 0%, transparent 35%);
      "
      >
      </div>
    </div>
  </section>

  {brandStorySections.map((s, i) => <BrandStorySection section={s} continued={i > 0} />)}

  <!-- FEATURES: 01 02 03 -->
  <section
    id="pause-features"
    style="
  padding: 7rem 3rem;
  background: var(--white);
  text-align: center;
"
  >
    <h2
      class="reveal"
      style="
    font-size: clamp(1.8rem,4vw,2.8rem);
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 4rem;
  "
    >
      Κάθε box περιέχει
    </h2>

    <div
      class="pause-features__grid"
      style="
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
  "
    >
      <div class="reveal" style="padding: 1rem; position: relative;">
        <p
          style="
        font-size: 7rem; font-weight: 800;
        color: rgba(196,149,106,0.15);
        line-height: 1;
        margin-bottom: -1.5rem;
        font-family: var(--font);
      "
        >
          01
        </p>
        <p style="font-size: 0.95rem; font-weight: 600; color: var(--ink); margin-bottom: 0.5rem;">Άσκηση</p>
        <p style="font-size: 0.83rem; font-weight: 300; color: var(--ink-soft);">
          Κάρτες αφύπνισης και ασκήσεων σε 3 επίπεδα δυσκολίας.
        </p>
      </div>
      <div class="reveal" data-delay="100" style="padding: 1rem; position: relative;">
        <p
          style="
        font-size: 7rem; font-weight: 800;
        color: rgba(196,149,106,0.15);
        line-height: 1;
        margin-bottom: -1.5rem;
      "
        >
          02
        </p>
        <p style="font-size: 0.95rem; font-weight: 600; color: var(--ink); margin-bottom: 0.5rem;">Επίγνωση</p>
        <p style="font-size: 0.83rem; font-weight: 300; color: var(--ink-soft);">
          Δομημένες στιγμές αυτοπαρατήρησης μέσα στην εργάσιμη μέρα.
        </p>
      </div>
      <div class="reveal" data-delay="200" style="padding: 1rem; position: relative;">
        <p
          style="
        font-size: 7rem; font-weight: 800;
        color: rgba(196,149,106,0.15);
        line-height: 1;
        margin-bottom: -1.5rem;
      "
        >
          03
        </p>
        <p style="font-size: 0.95rem; font-weight: 600; color: var(--ink); margin-bottom: 0.5rem;">Τελετουργία</p>
        <p style="font-size: 0.83rem; font-weight: 300; color: var(--ink-soft);">
          Κερί ritual anchor και οδηγός χρήσης για καθημερινή ρουτίνα.
        </p>
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section
    style="
  padding: 5rem 3rem;
  background: var(--teal);
  text-align: center;
"
  >
    <p
      class="reveal"
      style="
    font-size: 0.78rem; font-weight: 600;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: rgba(255,255,255,0.7); margin-bottom: 2.5rem;
  "
    >
      Τι λένε
    </p>

    <div style="max-width: 700px; margin: 0 auto; position: relative;">
      <p
        style="
      font-size: 5rem; font-weight: 800;
      color: rgba(255,255,255,0.2);
      line-height: 0.5;
      text-align: left;
      margin-bottom: 1rem;
    "
      >
        "
      </p>

      <p
        class="reveal"
        style="
      font-size: clamp(1.1rem,2.5vw,1.6rem);
      font-weight: 300;
      color: var(--white);
      line-height: 1.6;
      margin-bottom: 2rem;
    "
      >
        Οι κάρτες με βοήθησαν να σταματήσω τον αυτόματο πιλότο στη δουλειά. Μικρές παύσεις που άλλαξαν τον τρόπο που
        βιώνω την εργάσιμη μέρα.
      </p>

      <p
        style="
      font-size: 0.82rem; font-weight: 500;
      color: rgba(255,255,255,0.7);
    "
      >
        Μαρία Κ., Αθήνα
      </p>
    </div>
  </section>

  <!-- Κενό μεταξύ teal testimonial και split footer -->
  <div
    aria-hidden="true"
    style="height: clamp(2.25rem, 5vw, 3.75rem); background: var(--white);"
  >
  </div>

  <footer style="display: flex; flex-direction: column; background: var(--white);">
    <!-- 5rem κενό αριστερά/δεξιά γύρω από το split block -->
    <div
      class="site-footer-split-wrap"
      style="padding: 0 5rem; background: var(--white); box-sizing: border-box;"
    >
    <div
      id="etaireies"
      class="footer-split-grid"
      style="
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: min(560px, 72vh);
    overflow: hidden;
  "
    >
    <!-- 1: Dark brand -->
    <div
      style="
    background: #1C1712;
    padding: clamp(2.5rem, 6vw, 5rem) clamp(1.5rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1.25rem;
  "
    >
      <p
        style="
      font-size: clamp(1.2rem, 2.4vw, 1.45rem);
      font-weight: 600;
      color: #F6F2ED;
      letter-spacing: -0.02em;
    "
      >
        Με Πρόθεση
      </p>
      <p
        style="
      font-size: clamp(0.95rem, 1.8vw, 1.05rem);
      font-weight: 300;
      color: rgba(246, 242, 237, 0.58);
      line-height: 1.72;
      max-width: 26rem;
    "
      >
        Structured reflection tools · τελετουργική μορφή · καθημερινότητα.
      </p>
      <p
        style="
      font-size: clamp(0.95rem, 1.8vw, 1.05rem);
      font-weight: 300;
      color: rgba(246, 242, 237, 0.58);
      line-height: 1.72;
      max-width: 26rem;
    "
      >
        Δημιουργημένο από ψυχοθεραπεύτρια.
      </p>
    </div>

    <!-- 2: Peach — CTA (ίδιο ύψος στήλης, κεντραρισμένο) -->
    <div
      style="
    background: #F6F2ED;
    padding: clamp(2.5rem, 6vw, 5rem) clamp(1.5rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1.75rem;
  "
    >
      <p
        style="
      font-size: clamp(1.15rem, 2.2vw, 1.45rem);
      font-weight: 700;
      color: #1C1712;
      line-height: 1.35;
      max-width: 18rem;
    "
      >
        Ναι, θέλω να ξεκινήσω<br />Με Πρόθεση.
      </p>
      <a href="https://www.instagram.com/meprothesi/" target="_blank" rel="noopener noreferrer" class="btn-pill">
        Βρες μας στο Instagram
      </a>
    </div>
    </div>
    </div>

    <!-- Colophon -->
    <div
      class="site-colophon"
      style="
    text-align: center;
    padding: 1.35rem 5rem 2.25rem;
    font-size: 0.75rem;
    font-weight: 400;
    color: rgba(28, 23, 18, 0.48);
    background: var(--white);
    line-height: 1.6;
  "
    >
      © 2026 by Με Πρόθεση. Powered and secured by
      <a
        href="https://www.itdev.gr/"
        target="_blank"
        rel="noopener noreferrer"
        style="color: var(--ink); text-decoration: underline; text-underline-offset: 2px;">ITDEV</a>.
    </div>
  </footer>
</Layout>
