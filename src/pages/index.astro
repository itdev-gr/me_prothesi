---
import Layout from '../layouts/Layout.astro';
import BrandStorySection from '../components/BrandStorySection.astro';
import { brandStorySections } from '../data/brandStory';
---

<Layout title="Με Πρόθεση">
  <link
    slot="head"
    rel="preload"
    href="/images/hero2.mp4"
    as="video"
    type="video/mp4"
  />
  <section
    class="site-hero"
    style="
  min-height: 100vh;
  min-height: 100svh;
  background: #F6F2ED;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: stretch;
  overflow: hidden;
"
  >
    <!-- LEFT: Text -->
    <div
      style="
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(5rem, 12vw, 8rem) clamp(2rem, 5vw, 6rem);
    max-width: 680px;
    width: 100%;
    justify-self: center;
    min-height: 0;
  "
    >
      <p
        style="
      font-size: 0.62rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(28,23,18,0.4);
      margin-bottom: 2.5rem;
      font-family: var(--font-body);
    "
      >
        Δημιουργημένο από ψυχοθεραπεύτρια
      </p>

      <h1
        style="
      font-family: var(--font-display);
      font-size: clamp(3rem, 5vw, 4.5rem);
      font-weight: 300;
      color: var(--ink);
      line-height: 1.05;
      letter-spacing: -0.01em;
      margin-bottom: 0.25rem;
    "
      >
        Η αλλαγή ξεκινά
      </h1>

      <h1
        style="
      font-family: var(--font-display);
      font-size: clamp(3rem, 5vw, 4.5rem);
      font-weight: 300;
      font-style: italic;
      color: var(--accent);
      line-height: 1.05;
      letter-spacing: -0.01em;
      margin-bottom: 2.5rem;
    "
      >
        Με Πρόθεση.
      </h1>

      <div
        style="
      width: 36px; height: 1px;
      background: var(--accent);
      margin-bottom: 2rem;
      opacity: 0.6;
    "
      >
      </div>

      <p
        style="
      font-family: var(--font-body);
      font-size: 1rem;
      font-weight: 400;
      color: var(--ink);
      line-height: 1.65;
      max-width: 380px;
      margin-bottom: 0.6rem;
    "
      >
        Μικρές παύσεις για πιο συνειδητή εργασία.
      </p>

      <p
        style="
      font-family: var(--font-body);
      font-size: 0.85rem;
      font-weight: 300;
      color: var(--ink-soft);
      line-height: 1.8;
      max-width: 380px;
      margin-bottom: 4rem;
    "
      >
        Δομημένες ψυχοεκπαιδευτικές εμπειρίες σε μορφή τελετουργίας. Η αλλαγή δεν ξεκινά εξωτερικά. Ξεκινά εσωτερικά.
      </p>

      <!-- Stats row -->
      <div
        style="
      display: flex;
      gap: 2.5rem;
      padding-top: 2rem;
      border-top: 1px solid rgba(28,23,18,0.1);
    "
      >
        <div>
          <p
            style="font-family: var(--font-display); font-size: 1.8rem; font-weight: 500; color: var(--ink); line-height: 1; letter-spacing: -0.02em;"
          >
            7–10
          </p>
          <p
            style="font-family: var(--font-body); font-size: 0.6rem; font-weight: 500; color: rgba(28,23,18,0.4); margin-top: 0.3rem; letter-spacing: 0.12em; text-transform: uppercase;"
          >
            ημέρες / box
          </p>
        </div>
        <div style="width:1px; background: rgba(28,23,18,0.1);"></div>
        <div>
          <p
            style="font-family: var(--font-display); font-size: 1.8rem; font-weight: 500; color: var(--ink); line-height: 1; letter-spacing: -0.02em;"
          >
            10+
          </p>
          <p
            style="font-family: var(--font-body); font-size: 0.6rem; font-weight: 500; color: rgba(28,23,18,0.4); margin-top: 0.3rem; letter-spacing: 0.12em; text-transform: uppercase;"
          >
            κάρτες ασκήσεων
          </p>
        </div>
        <div style="width:1px; background: rgba(28,23,18,0.1);"></div>
        <div>
          <p
            style="font-family: var(--font-display); font-size: 1.8rem; font-weight: 500; color: var(--ink); line-height: 1; letter-spacing: -0.02em;"
          >
            1
          </p>
          <p
            style="font-family: var(--font-body); font-size: 0.6rem; font-weight: 500; color: rgba(28,23,18,0.4); margin-top: 0.3rem; letter-spacing: 0.12em; text-transform: uppercase;"
          >
            ψυχοθεραπεύτρια
          </p>
        </div>
      </div>
    </div>

    <!-- RIGHT: Hero video -->
    <div
      style="
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    min-height: 100svh;
    background: #C4956A;
  "
    >
      <video
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        aria-label="Pause Mode"
        style="
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
      "
      >
        <source src="/images/hero2.mp4" type="video/mp4" />
      </video>
      <div
        style="
        position: absolute; inset: 0;
        background: linear-gradient(to right, rgba(196,149,106,0.35) 0%, transparent 35%);
      "
      >
      </div>

      <!-- Badge -->
      <div
        style="
        position: absolute;
        bottom: 3rem; left: 2rem;
        background: rgba(246,242,237,0.15);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(246,242,237,0.25);
        border-radius: 12px;
        padding: 1rem 1.5rem;
      "
      >
        <p
          style="font-family: var(--font-body); font-size: 0.62rem; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(246,242,237,0.7); margin-bottom: 0.25rem;"
        >
          Box 01
        </p>
        <p
          style="font-family: var(--font-display); font-size: 1rem; font-weight: 400; color: #F6F2ED; font-style: italic;"
        >
          Pause Mode
        </p>
      </div>
    </div>
  </section>

  {brandStorySections.map((s) => <BrandStorySection section={s} />)}

  <!-- FEATURES: 01 02 03 -->
  <section
    id="section-03"
    style="
  padding: 7rem 3rem;
  background: var(--white);
  text-align: center;
"
  >
    <h2
      class="reveal"
      style="
    font-size: clamp(1.8rem,4vw,2.8rem);
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 4rem;
  "
    >
      Κάθε box περιέχει
    </h2>

    <div
      style="
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto 3rem;
  "
    >
      <div class="reveal" style="padding: 1rem; position: relative;">
        <p
          style="
        font-size: 7rem; font-weight: 800;
        color: rgba(196,149,106,0.15);
        line-height: 1;
        margin-bottom: -1.5rem;
        font-family: var(--font);
      "
        >
          01
        </p>
        <p style="font-size: 0.95rem; font-weight: 600; color: var(--ink); margin-bottom: 0.5rem;">Άσκηση</p>
        <p style="font-size: 0.83rem; font-weight: 300; color: var(--ink-soft);">
          Κάρτες αφύπνισης και ασκήσεων σε 3 επίπεδα δυσκολίας.
        </p>
      </div>
      <div class="reveal" data-delay="100" style="padding: 1rem; position: relative;">
        <p
          style="
        font-size: 7rem; font-weight: 800;
        color: rgba(196,149,106,0.15);
        line-height: 1;
        margin-bottom: -1.5rem;
      "
        >
          02
        </p>
        <p style="font-size: 0.95rem; font-weight: 600; color: var(--ink); margin-bottom: 0.5rem;">Επίγνωση</p>
        <p style="font-size: 0.83rem; font-weight: 300; color: var(--ink-soft);">
          Δομημένες στιγμές αυτοπαρατήρησης μέσα στην εργάσιμη μέρα.
        </p>
      </div>
      <div class="reveal" data-delay="200" style="padding: 1rem; position: relative;">
        <p
          style="
        font-size: 7rem; font-weight: 800;
        color: rgba(196,149,106,0.15);
        line-height: 1;
        margin-bottom: -1.5rem;
      "
        >
          03
        </p>
        <p style="font-size: 0.95rem; font-weight: 600; color: var(--ink); margin-bottom: 0.5rem;">Τελετουργία</p>
        <p style="font-size: 0.83rem; font-weight: 300; color: var(--ink-soft);">
          Κερί ritual anchor και οδηγός χρήσης για καθημερινή ρουτίνα.
        </p>
      </div>
    </div>

    <a href="#etaireies" class="btn-pill reveal">Δες για εταιρείες</a>
  </section>

  <!-- TESTIMONIAL -->
  <section
    style="
  padding: 5rem 3rem;
  background: var(--teal);
  text-align: center;
"
  >
    <p
      class="reveal"
      style="
    font-size: 0.78rem; font-weight: 600;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: rgba(255,255,255,0.7); margin-bottom: 2.5rem;
  "
    >
      Τι λένε
    </p>

    <div style="max-width: 700px; margin: 0 auto; position: relative;">
      <p
        style="
      font-size: 5rem; font-weight: 800;
      color: rgba(255,255,255,0.2);
      line-height: 0.5;
      text-align: left;
      margin-bottom: 1rem;
    "
      >
        "
      </p>

      <p
        class="reveal"
        style="
      font-size: clamp(1.1rem,2.5vw,1.6rem);
      font-weight: 300;
      color: var(--white);
      line-height: 1.6;
      margin-bottom: 2rem;
    "
      >
        Οι κάρτες με βοήθησαν να σταματήσω τον αυτόματο πιλότο στη δουλειά. Μικρές παύσεις που άλλαξαν τον τρόπο που
        βιώνω την εργάσιμη μέρα.
      </p>

      <p
        style="
      font-size: 0.82rem; font-weight: 500;
      color: rgba(255,255,255,0.7);
    "
      >
        Μαρία Κ., Αθήνα
      </p>
    </div>
  </section>

  <!-- Κενό μεταξύ teal testimonial και split footer -->
  <div
    aria-hidden="true"
    style="height: clamp(2.25rem, 5vw, 3.75rem); background: var(--white);"
  >
  </div>

  <footer style="display: flex; flex-direction: column; background: var(--white);">
    <!-- 5rem κενό αριστερά/δεξιά γύρω από το split block -->
    <div
      class="site-footer-split-wrap"
      style="padding: 0 5rem; background: var(--white); box-sizing: border-box;"
    >
    <div
      id="etaireies"
      style="
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: min(560px, 72vh);
    overflow: hidden;
  "
    >
    <!-- 1: Dark brand -->
    <div
      style="
    background: #1C1712;
    padding: clamp(2.5rem, 6vw, 5rem) clamp(1.5rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1.25rem;
  "
    >
      <p
        style="
      font-size: clamp(1.2rem, 2.4vw, 1.45rem);
      font-weight: 600;
      color: #F6F2ED;
      letter-spacing: -0.02em;
    "
      >
        Με Πρόθεση
      </p>
      <p
        style="
      font-size: clamp(0.95rem, 1.8vw, 1.05rem);
      font-weight: 300;
      color: rgba(246, 242, 237, 0.58);
      line-height: 1.72;
      max-width: 26rem;
    "
      >
        Structured reflection tools · τελετουργική μορφή · καθημερινότητα.
      </p>
      <p
        style="
      font-size: clamp(0.95rem, 1.8vw, 1.05rem);
      font-weight: 300;
      color: rgba(246, 242, 237, 0.58);
      line-height: 1.72;
      max-width: 26rem;
    "
      >
        Δημιουργημένο από ψυχοθεραπεύτρια.
      </p>
    </div>

    <!-- 2: Peach — CTA (ίδιο ύψος στήλης, κεντραρισμένο) -->
    <div
      style="
    background: #F6F2ED;
    padding: clamp(2.5rem, 6vw, 5rem) clamp(1.5rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1.75rem;
  "
    >
      <p
        style="
      font-size: clamp(1.15rem, 2.2vw, 1.45rem);
      font-weight: 700;
      color: #1C1712;
      line-height: 1.35;
      max-width: 18rem;
    "
      >
        Ναι, θέλω να ξεκινήσω<br />Με Πρόθεση.
      </p>
      <a href="https://www.instagram.com/meprothesi/" target="_blank" rel="noopener noreferrer" class="btn-pill">
        Βρες μας στο Instagram
      </a>
    </div>
    </div>
    </div>

    <!-- Colophon -->
    <div
      class="site-colophon"
      style="
    text-align: center;
    padding: 1.35rem 5rem 2.25rem;
    font-size: 0.75rem;
    font-weight: 400;
    color: rgba(28, 23, 18, 0.48);
    background: var(--white);
    line-height: 1.6;
  "
    >
      © 2026 by Με Πρόθεση. Powered and secured by
      <a
        href="https://www.itdev.gr/"
        target="_blank"
        rel="noopener noreferrer"
        style="color: var(--ink); text-decoration: underline; text-underline-offset: 2px;">ITDEV</a>.
    </div>
  </footer>
</Layout>
