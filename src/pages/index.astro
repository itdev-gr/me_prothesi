---
import Layout from '../layouts/Layout.astro';
import BrandStoryChapter from '../components/BrandStoryChapter.astro';
import { getBrandStoryChapters } from '../data/brandStory';

const brandStoryChapters = getBrandStoryChapters();
---

<Layout title="Με Πρόθεση">
  <link
    slot="head"
    rel="preload"
    href="/images/hero2.mp4"
    as="video"
    type="video/mp4"
  />
  <section class="site-hero" aria-label="Εισαγωγή">
    <!-- LEFT: Text -->
    <div class="site-hero__content">
      <div class="site-hero__intro">
        <p class="site-hero__kicker">Δημιουργημένο από ψυχοθεραπεύτρια</p>

        <h1 class="site-hero__title" id="hero-title">
          <span class="site-hero__title-line1">Η αλλαγή ξεκινά</span>
          <span class="site-hero__title-accent-block">
            <span class="site-hero__title-accent">Με Πρόθεση.</span>
            <span class="site-hero__rule" aria-hidden="true"></span>
          </span>
        </h1>

        <p class="site-hero__lead">Μικρές παύσεις για πιο συνειδητή εργασία.</p>

        <p class="site-hero__body">
          Δομημένες ψυχοεκπαιδευτικές εμπειρίες σε μορφή τελετουργίας. Η αλλαγή δεν ξεκινά εξωτερικά· ξεκινά εσωτερικά.
        </p>
      </div>
    </div>

    <!-- RIGHT: Hero video -->
    <div class="site-hero__media">
      <video
        class="site-hero__video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        aria-label="Pause Mode"
      >
        <source src="/images/hero2.mp4" type="video/mp4" />
      </video>
      <div class="site-hero__media-gradient" aria-hidden="true"></div>
    </div>
  </section>

  {
    brandStoryChapters.map((chapter, i) => (
      <BrandStoryChapter
        chapterId={chapter.chapterId}
        label={chapter.label}
        title={chapter.title}
        intro={chapter.intro}
        sections={chapter.sections}
        continued={i > 0}
      />
    ))
  }

  <!-- TESTIMONIAL -->
  <section
    style="
  padding: 4.25rem 3rem;
  background: var(--teal);
  text-align: center;
"
  >
    <p
      class="reveal"
      style="
    font-size: 0.78rem; font-weight: 600;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: rgba(255,255,255,0.7); margin-bottom: 2.5rem;
  "
    >
      Τι λένε
    </p>

    <div style="max-width: 700px; margin: 0 auto; position: relative;">
      <p
        style="
      font-size: 5rem; font-weight: 800;
      color: rgba(255,255,255,0.2);
      line-height: 0.5;
      text-align: left;
      margin-bottom: 1rem;
    "
      >
        "
      </p>

      <p
        class="reveal"
        style="
      font-size: clamp(1.1rem,2.5vw,1.6rem);
      font-weight: 300;
      color: var(--white);
      line-height: 1.6;
      margin-bottom: 2rem;
    "
      >
        Οι κάρτες με βοήθησαν να σταματήσω τον αυτόματο πιλότο στη δουλειά. Μικρές παύσεις που άλλαξαν τον τρόπο που
        βιώνω την εργάσιμη μέρα.
      </p>

      <p
        style="
      font-size: 0.82rem; font-weight: 500;
      color: rgba(255,255,255,0.7);
    "
      >
        Μαρία Κ., Αθήνα
      </p>
    </div>
  </section>

  <!-- Κενό μεταξύ teal testimonial και split footer -->
  <div
    aria-hidden="true"
    style="height: clamp(2.25rem, 5vw, 3.75rem); background: var(--white);"
  >
  </div>

  <footer style="display: flex; flex-direction: column; background: var(--white);">
    <!-- 5rem κενό αριστερά/δεξιά γύρω από το split block -->
    <div
      class="site-footer-split-wrap"
      style="padding: 0 5rem; background: var(--white); box-sizing: border-box;"
    >
    <div
      id="etaireies"
      class="footer-split-grid"
      style="
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: min(560px, 72vh);
    overflow: hidden;
  "
    >
    <!-- 1: Dark brand -->
    <div
      style="
    background: #1C1712;
    padding: clamp(2.5rem, 6vw, 5rem) clamp(1.5rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1.25rem;
  "
    >
      <p
        style="
      font-size: clamp(1.2rem, 2.4vw, 1.45rem);
      font-weight: 600;
      color: #F6F2ED;
      letter-spacing: -0.02em;
    "
      >
        Με Πρόθεση
      </p>
      <p
        style="
      font-size: clamp(0.95rem, 1.8vw, 1.05rem);
      font-weight: 300;
      color: rgba(246, 242, 237, 0.58);
      line-height: 1.72;
      max-width: 26rem;
    "
      >
        Structured reflection tools · τελετουργική μορφή · καθημερινότητα.
      </p>
      <p
        style="
      font-size: clamp(0.95rem, 1.8vw, 1.05rem);
      font-weight: 300;
      color: rgba(246, 242, 237, 0.58);
      line-height: 1.72;
      max-width: 26rem;
    "
      >
        Δημιουργημένο από ψυχοθεραπεύτρια.
      </p>
    </div>

    <!-- 2: Peach — CTA (ίδιο ύψος στήλης, κεντραρισμένο) -->
    <div
      style="
    background: #F6F2ED;
    padding: clamp(2.5rem, 6vw, 5rem) clamp(1.5rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1.75rem;
  "
    >
      <p
        style="
      font-size: clamp(1.15rem, 2.2vw, 1.45rem);
      font-weight: 700;
      color: #1C1712;
      line-height: 1.35;
      max-width: 18rem;
    "
      >
        Ναι, θέλω να ξεκινήσω<br />Με Πρόθεση.
      </p>
      <a href="https://www.instagram.com/meprothesi/" target="_blank" rel="noopener noreferrer" class="btn-pill">
        Βρες μας στο Instagram
      </a>
    </div>
    </div>
    </div>

    <!-- Colophon -->
    <div
      class="site-colophon"
      style="
    text-align: center;
    padding: 1.35rem 5rem 2.25rem;
    font-size: 0.75rem;
    font-weight: 400;
    color: rgba(28, 23, 18, 0.48);
    background: var(--white);
    line-height: 1.6;
  "
    >
      © 2026 by Με Πρόθεση. Powered and secured by
      <a
        href="https://www.itdev.gr/"
        target="_blank"
        rel="noopener noreferrer"
        style="color: var(--ink); text-decoration: underline; text-underline-offset: 2px;">ITDEV</a>.
    </div>
  </footer>
</Layout>
