---
import '../styles/global.css';

export interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      @media (max-width: 768px) {
        nav {
          padding: 1rem 1.5rem !important;
        }
        nav div:last-child {
          display: none !important;
        }

        section {
          padding: 4rem 1.5rem !important;
          grid-template-columns: 1fr !important;
          gap: 2.5rem !important;
        }

        footer {
          grid-template-columns: 1fr !important;
        }

        h1 {
          font-size: 2.5rem !important;
        }
        h2 {
          font-size: 2rem !important;
        }

        section > div[style*='grid-template-columns: repeat(3'] {
          grid-template-columns: 1fr !important;
        }

        /* Hero right image hidden on mobile */
        section > div[style*='position: absolute; right: 0'] {
          display: none !important;
        }

        section > div[style*='grid-template-columns: 1fr 1fr'] {
          grid-template-columns: 1fr !important;
        }

        /* Brand story: flex row → στήλη, εικόνα κεντραρισμένη */
        section.brand-story {
          flex-direction: column !important;
          align-items: stretch !important;
        }
        section.brand-story .brand-story__media {
          align-self: center;
        }
      }
    </style>
  </head>
  <body>
    <nav
      style="
  position: fixed; top: 0; left: 0; width: 100%; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.25rem 3rem;
  background: transparent;
  transition: background 0.3s ease;
"
      id="navbar"
    >
      <div style="display: flex; align-items: center; gap: 0.75rem;">
        <div
          style="
      width: 32px; height: 32px;
      background: var(--ink);
      border-radius: 4px;
      display: flex; align-items: center; justify-content: center;
    "
        >
          <span style="color: white; font-size: 0.75rem; font-weight: 700;">ΜΠ</span>
        </div>
        <div>
          <p style="font-size: 0.9rem; font-weight: 600; color: var(--ink); line-height: 1.2;">Με Πρόθεση</p>
          <p style="font-size: 0.65rem; color: var(--ink-soft); letter-spacing: 0.05em;">by ψυχοθεραπεύτρια</p>
        </div>
      </div>

      <a
        href="https://www.instagram.com/meprothesi/"
        target="_blank"
        rel="noopener noreferrer"
        style="font-size: 0.82rem; color: var(--ink); text-decoration: none; font-weight: 400;">Instagram</a
      >
    </nav>

    <main><slot /></main>

    <script>
      const navbar = document.getElementById('navbar');
      if (navbar) {
        window.addEventListener('scroll', () => {
          navbar.style.background =
            window.scrollY > 50 ? 'rgba(255,255,255,0.95)' : 'transparent';
          navbar.style.backdropFilter = window.scrollY > 50 ? 'blur(10px)' : 'none';
          navbar.style.boxShadow =
            window.scrollY > 50 ? '0 2px 20px rgba(0,0,0,0.08)' : 'none';
        });
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target;
              const delay = Number((el as HTMLElement).dataset.delay) || 0;
              setTimeout(() => {
                el.classList.add('visible');
              }, delay);
              observer.unobserve(el);
            }
          });
        },
        { threshold: 0.1 }
      );

      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
